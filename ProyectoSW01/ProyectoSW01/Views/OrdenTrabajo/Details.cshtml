@model ProyectoSW01.Models.OrdenTrabajoConDetalle

@{
    ViewData["Title"] = "Detalle de orden de trabajo";
    var orden = Model.Orden;
    var detalles = Model.Detalles ?? new List<ProyectoSW01.Models.OrdenTrabajoDetalle>();
}

<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- Material Icons -->
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />

<div class="max-w-5xl mx-auto px-4 py-8">

    <!-- Encabezado -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
                <span class="material-icons text-blue-700">description</span>
                Orden de trabajo #@orden.OrdenId
            </h1>
            <p class="text-sm text-gray-500 mt-1">
                Fecha: <span class="font-semibold">@orden.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
            </p>
        </div>

        <a asp-action="ListarOrdenesDeTrabajo"
           class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-800 rounded-lg hover:bg-gray-200 text-sm">
            <span class="material-icons text-sm mr-1">arrow_back</span>
            Volver a órdenes
        </a>
    </div>

    <!-- Cabecera -->
    <div class="bg-white shadow rounded-xl p-6 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-700">
            <div>
                <p class="font-semibold flex items-center gap-2">
                    <span class="material-icons text-blue-700 text-sm">directions_car</span>
                    Vehículo ID:
                    <span class="font-normal">@orden.VehiculoId</span>
                </p>
            </div>
            <div>
                <p class="font-semibold flex items-center gap-2">
                    <span class="material-icons text-blue-700 text-sm">assignment</span>
                    Diagnóstico ID:
                    <span class="font-normal">
                        @(orden.DiagnosticoId.HasValue? orden.DiagnosticoId.ToString() : "-")
                    </span>
                </p>
            </div>
            <div>
                <p class="font-semibold flex items-center gap-2">
                    <span class="material-icons text-blue-700 text-sm">engineering</span>
                    Mecánico ID:
                    <span class="font-normal">
                        @(orden.MecanicoId.HasValue? orden.MecanicoId.ToString() : "-")
                    </span>
                </p>
            </div>
            <div>
                <p class="font-semibold flex items-center gap-2">
                    <span class="material-icons text-blue-700 text-sm">flag</span>
                    Estado:
                    <span class="font-normal">@orden.Estado</span>
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(orden.Observaciones))
        {
            <div class="mt-4">
                <p class="text-sm text-gray-700 font-semibold mb-1 flex items-center gap-2">
                    <span class="material-icons text-blue-700 text-sm">notes</span>
                    Observaciones
                </p>
                <p class="text-sm text-gray-600 bg-gray-50 rounded-lg p-3">
                    @orden.Observaciones
                </p>
            </div>
        }
    </div>

    <!-- Detalle de servicios -->
    <div class="bg-white shadow rounded-xl overflow-x-auto mb-4">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-blue-700 text-white">
                <tr>
                    <th class="px-4 py-3 text-left font-semibold">Servicio</th>
                    <th class="px-4 py-3 text-left font-semibold">Cantidad</th>
                    <th class="px-4 py-3 text-left font-semibold">Precio</th>
                    <th class="px-4 py-3 text-left font-semibold">Subtotal</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @if (detalles.Any())
                {
                    foreach (var det in detalles)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-3">@det.ServicioNombre</td>
                            <td class="px-4 py-3">@det.Cantidad</td>
                            <td class="px-4 py-3">@det.Precio.ToString("C")</td>
                            <td class="px-4 py-3">@det.Subtotal.ToString("C")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-4 py-4 text-center text-gray-500">
                            Esta orden no tiene servicios registrados en el detalle.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Total final -->
    <div class="flex justify-end">
        <p class="text-lg text-gray-800">
            Total de la orden:
            <span class="font-bold">@orden.Total.ToString("C")</span>
        </p>
    </div>

</div>
