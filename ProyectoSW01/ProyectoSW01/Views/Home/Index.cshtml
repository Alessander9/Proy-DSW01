@{
    ViewData["Title"] = "Taller Mecánico";
}

<!-- Tailwind CSS v4 CDN -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- Material Icons -->
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">

<style>
    /* Animaciones simples */
    .fade-in {
        animation: fadeIn 1s ease-in forwards;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Carrusel */
    .carousel {
        position: relative;
        overflow: hidden;
        height: 350px;
        border-radius: 1rem;
    }
    .carousel-track {
        display: flex;
        width: 300%;
        animation: slide 12s infinite linear;
    }
    .carousel-track img {
        width: 100%;
        height: 350px;
        object-fit: cover;
    }
    @@keyframes slide {
        0% { transform: translateX(0%); }
        30% { transform: translateX(0%); }

        35% { transform: translateX(-100%); }
        65% { transform: translateX(-100%); }

        70% { transform: translateX(-200%); }
        100% { transform: translateX(-200%); }
    }
</style>

<!-- ===================== HERO ===================== -->
<section class="bg-gray-900 text-white min-h-screen flex items-center fade-in">
    <div class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-10 items-center">

        <div>
            <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
                El Mejor Servicio Automotriz<br> para tu Vehículo
            </h1>
            <p class="text-gray-300 text-lg mb-8">
                Mantenimiento, reparación, diagnóstico computarizado y repuestos de alta calidad.
            </p>

            <a href="#servicios"
               class="inline-flex items-center bg-red-600 hover:bg-red-700 transition px-6 py-3 rounded-xl text-white font-medium shadow-xl">
                Ver Servicios
                <span class="material-icons-round ml-2">arrow_forward</span>
            </a>

            <button onclick="openModal()"
                    class="inline-flex items-center ml-4 border border-white hover:bg-white hover:text-black transition px-6 py-3 rounded-xl font-medium">
                Agendar Cita
                <span class="material-icons-round ml-2">event</span>
            </button>
        </div>

        <!-- Carrusel -->
        <div class="carousel shadow-2xl">
            <div class="carousel-track">
                <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=1200" alt="">
                <img src="https://images.unsplash.com/photo-1493238792000-8113da705763?q=80&w=1200" alt="">
                <img src="https://images.unsplash.com/photo-1537047902294-62a40c20a6ae?q=80&w=1200" alt="">
            </div>
        </div>
    </div>
</section>

<!-- ===================== SERVICIOS ===================== -->
<section id="servicios" class="py-20 bg-gray-100 fade-in">
    <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Nuestros Servicios</h2>

        <div class="grid md:grid-cols-3 gap-10">

            <div class="bg-white rounded-2xl shadow-lg p-8 hover:scale-105 transition">
                <span class="material-icons-round text-red-600 text-5xl mb-4">build_circle</span>
                <h3 class="text-xl font-bold mb-2">Mantenimiento General</h3>
                <p class="text-gray-600">Cambios de aceite, filtros y revisión completa.</p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-8 hover:scale-105 transition">
                <span class="material-icons-round text-red-600 text-5xl mb-4">car_repair</span>
                <h3 class="text-xl font-bold mb-2">Reparación de Motor</h3>
                <p class="text-gray-600">Diagnóstico avanzado y reparación profesional.</p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-8 hover:scale-105 transition">
                <span class="material-icons-round text-red-600 text-5xl mb-4">electrical_services</span>
                <h3 class="text-xl font-bold mb-2">Sistema Eléctrico</h3>
                <p class="text-gray-600">Escaneo computarizado OBD2 y reparación eléctrica.</p>
            </div>

        </div>
    </div>
</section>

<!-- ===================== PRODUCTOS ===================== -->
<section id="productos" class="py-20 fade-in">
    <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Productos y Repuestos</h2>

        <div class="grid md:grid-cols-4 gap-10">

            <div class="bg-white border rounded-xl shadow hover:shadow-xl transition p-4">
                <img src="https://images.unsplash.com/photo-1580273916550-e323be2ae537?q=80&w=800"
                     class="rounded-lg mb-4">
                <h3 class="font-bold text-lg">Aceite 5W30</h3>
                <span class="block mt-3 font-bold text-red-600 text-xl">S/ 35.00</span>
            </div>

            <div class="bg-white border rounded-xl shadow hover:shadow-xl transition p-4">
                <img src="https://images.unsplash.com/photo-1502877338535-766e1452684a?q=80&w=800"
                     class="rounded-lg mb-4">
                <h3 class="font-bold text-lg">Filtro de Aceite</h3>
                <span class="block mt-3 font-bold text-red-600 text-xl">S/ 25.00</span>
            </div>

            <div class="bg-white border rounded-xl shadow hover:shadow-xl transition p-4">
                <img src="https://images.unsplash.com/photo-1593378024934-6a19ebf6b5e8?q=80&w=800"
                     class="rounded-lg mb-4">
                <h3 class="font-bold text-lg">Pastillas de Freno</h3>
                <span class="block mt-3 font-bold text-red-600 text-xl">S/ 80.00</span>
            </div>

            <div class="bg-white border rounded-xl shadow hover:shadow-xl transition p-4">
                <img src="https://images.unsplash.com/photo-1632828486680-f6a4b1a1c1a7?q=80&w=800"
                     class="rounded-lg mb-4">
                <h3 class="font-bold text-lg">Bujías</h3>
                <span class="block mt-3 font-bold text-red-600 text-xl">S/ 15.00</span>
            </div>

        </div>
    </div>
</section>

<!-- ===================== FORMULARIO MODAL ===================== -->
<div id="modalCita"
     class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden justify-center items-center z-50">

    <div class="bg-white p-8 rounded-2xl shadow-2xl w-11/12 md:w-1/3 fade-in relative">

        <button onclick="closeModal()" class="absolute right-4 top-4 text-gray-500 hover:text-black">
            <span class="material-icons-round">close</span>
        </button>

        <h2 class="text-2xl font-bold mb-6 text-center">Agendar Cita</h2>

        <form class="space-y-4">
            <input type="text" placeholder="Nombre completo"
                   class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-red-600">

            <input type="email" placeholder="Correo electrónico"
                   class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-red-600">

            <input type="text" placeholder="Placa del vehículo"
                   class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-red-600">

            <input type="date"
                   class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-red-600">

            <textarea placeholder="Detalle de la solicitud"
                      class="w-full border p-3 rounded-lg h-24 focus:ring-2 focus:ring-red-600"></textarea>

            <button type="submit"
                    class="w-full bg-red-600 hover:bg-red-700 text-white p-3 rounded-lg font-semibold">
                Reservar Cita
            </button>
        </form>

    </div>
</div>

<!-- ===================== FOOTER ===================== -->
<footer class="bg-gray-900 text-gray-300 py-10 mt-20 text-center">
    © 2025 Taller Mecánico — Todos los derechos reservados
</footer>

<!-- ===================== JS ===================== -->
<script>
    function openModal() {
        document.getElementById('modalCita').classList.remove('hidden');
        document.getElementById('modalCita').classList.add('flex');
    }

    function closeModal() {
        document.getElementById('modalCita').classList.add('hidden');
        document.getElementById('modalCita').classList.remove('flex');
    }
</script>
