@model ProyectoSW01.Models.Repuesto

@{
    ViewData["Title"] = "Detalles del Repuesto";
}

<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- Material Icons -->
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />

<div class="max-w-3xl mx-auto px-4 py-8">

    <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-2 mb-6">
        <span class="material-icons text-blue-700">info</span>
        Detalles del Repuesto
    </h1>

    <div class="bg-white shadow rounded-xl p-6">
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">

            <div>
                <dt class="font-semibold text-gray-600 flex items-center gap-1">
                    <span class="material-icons text-sm text-blue-700">fingerprint</span>
                    ID
                </dt>
                <dd class="mt-1 text-gray-900">@Model.RepuestoId</dd>
            </div>

            <div>
                <dt class="font-semibold text-gray-600 flex items-center gap-1">
                    <span class="material-icons text-sm text-blue-700">label</span>
                    Nombre
                </dt>
                <dd class="mt-1 text-gray-900">@Model.Nombre</dd>
            </div>

            <div>
                <dt class="font-semibold text-gray-600 flex items-center gap-1">
                    <span class="material-icons text-sm text-blue-700">paid</span>
                    Precio
                </dt>
                <dd class="mt-1 text-gray-900">@Model.Precio.ToString("C")</dd>
            </div>

            <div>
                <dt class="font-semibold text-gray-600 flex items-center gap-1">
                    <span class="material-icons text-sm text-blue-700">inventory_2</span>
                    Stock
                </dt>
                <dd class="mt-1 text-gray-900">@Model.Stock</dd>
            </div>

            <div class="md:col-span-2">
                <dt class="font-semibold text-gray-600 flex items-center gap-1">
                    <span class="material-icons text-sm text-blue-700">description</span>
                    Descripción
                </dt>
                <dd class="mt-1 text-gray-900">@Model.Descripcion</dd>
            </div>

        </dl>
    </div>

    <div class="mt-6 flex justify-end gap-3">
        <a asp-action="Edit" asp-route-id="@Model.RepuestoId"
           class="inline-flex items-center px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition">
            <span class="material-icons text-sm mr-1">edit</span>
            Editar
        </a>
        <a asp-action="ListarRepuestos"
           class="inline-flex items-center px-4 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 transition">
            <span class="material-icons text-sm mr-1">arrow_back</span>
            Volver
        </a>
    </div>

</div>
